# GEGET Raporlar - admin panel & Vercel Blob storage
# Copy to .env.local and fill in values for local development.
# On Vercel, set these as project environment variables.

# Vercel Blob: create a Blob store in the Vercel dashboard (Storage tab),
# connect it to the project, then "Pull env vars" or copy the token here.
BLOB_READ_WRITE_TOKEN=

# Admin password for the /admin panel. Pick something strong.
ADMIN_PASSWORD=

# Session cookie signing secret. Must be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
